<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0"
          jcr:primaryType="cq:Panel" 
          title="Generic List">
    <items jcr:primaryType="cq:WidgetCollection">
        <basic jcr:primaryType="cq:Widget" collapsed="false" collapsible="false" xtype="dialogfieldset">
            <items jcr:primaryType="cq:WidgetCollection">
                <generate-tags
                        jcr:primaryType="cq:Widget" 
                        fieldLabel="Generate Tags"
                        inputValue="true" 
                        name="./generateTags" 
                        type="checkbox" 
                        xtype="selection"/>
                <tag-namespace-title
                        jcr:primaryType="cq:Widget"
                        fieldLabel="Tag Namespace Title"
                        fieldDescription="If left blank the Page's title will be used."
                        name="./tagNamespaceTitle"
                        xtype="textfield"/>
                <tag-namespace 
                        jcr:primaryType="cq:Widget" 
                        fieldLabel="Tag Namespace"
                        fieldDescription="If left blank the Page's node name will be used."
                        name="./tagNamespace"
                        xtype="textfield"/>
            </items>
        </basic>
    </items>
</jcr:root>